# EstateFlow Customer Success FTE — Environment Variables
# Copy to .env and fill in your values
# Never commit .env to git

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fte_db
POSTGRES_USER=fte_user
POSTGRES_PASSWORD=your-strong-password-here

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Gmail API ──────────────────────────────────────────────────────────────────
# Download credentials.json from Google Cloud Console → APIs → Credentials
GMAIL_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"..."}}
# Generated by running OAuth consent flow
GMAIL_TOKEN_JSON={"token":"ya29...","refresh_token":"1//..."}
# Your support inbox
GMAIL_SUPPORT_EMAIL=support@estateflow.io

# ── Twilio / WhatsApp ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Feature Flags ──────────────────────────────────────────────────────────────
CHANNEL_GMAIL_ENABLED=true
CHANNEL_WHATSAPP_ENABLED=true
CHANNEL_WEB_FORM_ENABLED=true

# ── Agent Tuning ───────────────────────────────────────────────────────────────
MAX_RESPONSE_LENGTH=1500
AGENT_MAX_TURNS=15
